{
  "apps": [
    {
      "name": "nextjs-app",
      "script": "node_modules/next/dist/bin/next",
      "args": "start",
      "cwd": "./",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "PORT": 8000
      },
      "env_development": {
        "NODE_ENV": "development",
        "PORT": 3000
      },
      "watch": false,
      "autorestart": true,
      "max_memory_restart": "1G",
      "error_file": "./logs/nextjs-error.log",
      "out_file": "./logs/nextjs-out.log",
      "time": true
    }
  ]
}